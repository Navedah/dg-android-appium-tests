<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  DG Android Order Flow suite — runs on LambdaTest real devices via Appium.

  Before running:
    1. Upload DG APK:
         curl -u "$LT_USERNAME:$LT_ACCESS_KEY" \
           -X POST https://manual-api.lambdatest.com/app/upload/realDevice \
           -F "appFile=@DGApp.apk" -F "name=DollarGeneralApp"
         # copy the returned app_url (lt://APP_ID)

    2. Run suite:
         mvn test -Dsuite=dg-android.xml \
           -DappUrl=lt://YOUR_APP_ID \
           -DloginEmail=your@email.com \
           -DloginPassword=YourPassword \
           -DsearchKeyword=snickers \
           -DzipCode=30301
-->

<suite name="DG Android - Order Flow" verbose="1" parallel="false">

    <test name="DG Order Flow - Samsung Galaxy S25 (Android 15)">
        <parameter name="appUrl"  value="lt://APP1016025301776080228086620"/>
        <parameter name="device"  value="Galaxy S25"/>
        <parameter name="version" value="15"/>
        <classes>
            <class name="com.lambdatest.dg.tests.DGOrderFlowTest">
                <methods>
                    <include name="loginToDGApp"/>
                    <include name="addProductToCart"/>
                    <include name="placeOrder"/>
                    <include name="fullOrderFlowE2E"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>
